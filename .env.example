# ── AI Providers ──────────────────────────────────────────────────────────────
# The server tries providers in order: Ollama → Groq → OpenRouter → Google → Anthropic → OpenAI
# Only the keys you add will be attempted. Missing keys are skipped silently.

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Groq (fast inference, free tier) — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (multi-model gateway) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama local endpoint (default: http://localhost:11434/v1/chat/completions)
# OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions
# OLLAMA_API_KEY=ollama

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Protects /api/* routes — set any random string
NEXUS_TOKEN=

# ── Token Budget ──────────────────────────────────────────────────────────────
# Max output tokens per request (default: 2048, max allowed: 8192)
# NEXUS_MAX_TOKENS=2048

# ── Data APIs ─────────────────────────────────────────────────────────────────
# All optional — app degrades gracefully when keys are absent

# CoinGecko Demo — https://www.coingecko.com/en/api
CG_KEY=

# Finnhub (stock quotes) — https://finnhub.io
FINNHUB_KEY=

# NVD (CVE feed) — https://nvd.nist.gov/developers/request-an-api-key
NVD_KEY=

# The Guardian (news) — https://open-platform.theguardian.com
GUARDIAN_KEY=

# FRED (economic data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# AlienVault OTX (threat intel) — https://otx.alienvault.com
OTX_KEY=

# AISstream (live ship tracking) — https://aisstream.io
AISSTREAM_KEY=

# NASA FIRMS (fire hotspots) — https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_KEY=

# Firecrawl (web scraper) — https://firecrawl.dev
FIRECRAWL_KEY=

# Brave Search — https://api.search.brave.com
BRAVE_KEY=
